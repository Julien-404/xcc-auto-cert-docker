# Copy to .env and fill in. DO NOT COMMIT the real .env.

# --- Required ---

# Let's Encrypt registration email (used on first run to register the account).
ACME_EMAIL=admin@example.com

# XCC Web UI credentials. Same `acme-api` user with Supervisor role on each BMC.
# Must have had its forced-first-login password change cleared (see README).
XCC_USER=acme-api
XCC_PASS=REPLACE_ME

# Cloudflare API Token with Zone:DNS:Edit on your public parent zone (for LE DNS-01).
# Create at https://dash.cloudflare.com/profile/api-tokens
CF_Token=REPLACE_ME

# --- Optional ---

# Telegram alerting (enabled if BOTH TG_BOT_TOKEN and TG_CHAT_ID are set).
# Notifications are sent on every failed run. To also get a success heartbeat
# (useful to detect silent cron misfires), set TG_NOTIFY_ALWAYS=1.
# How to get these:
#   1. Create a bot with @BotFather → save the token below.
#   2. Send any message to your new bot from the account you want alerts on.
#   3. curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates" | jq '.result[0].message.chat.id'
# TG_BOT_TOKEN=REPLACE_ME
# TG_CHAT_ID=REPLACE_ME
# TG_NOTIFY_ALWAYS=0
# NOTIFY_SUBJECT=cert-renewer   # appears in the message — e.g. "cert-renewer (home lab)"

# Let's Encrypt endpoint. Default is prod; use `letsencrypt_test` for staging
# (unlimited issuance, fake issuer for testing).
# ACME_SERVER=letsencrypt_test

# CSR subject fields. Cosmetic only - LE issues certs based on SAN, not Subject.
# Defaults work; override only if your org has a compliance/convention need.
# CSR_COUNTRY=XX
# CSR_STATE=State
# CSR_CITY=City
# CSR_ORG=Organization
